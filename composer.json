{
	"name": "detain/myadmin-payza-payments",
	"type": "myadmin-plugin",
	"description": "Payza payment gateway integration plugin for the MyAdmin billing and hosting management platform. Provides checkout form generation, invoice processing, and IPN handling via the Payza (formerly AlertPay) payment processor.",
	"keywords": [
		"payza",
		"payment",
		"billing",
		"myadmin",
		"plugin",
		"gateway"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=7.4",
		"ext-soap": "*",
		"ext-bcmath": "*",
		"symfony/event-dispatcher": "^5.0||^6.0||^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminPayza\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminPayza\\Tests\\": "tests/"
		}
	}
}
